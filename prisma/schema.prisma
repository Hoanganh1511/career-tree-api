// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ShareMode {
  PRIVATE
  STRUCTURE_ONLY
  FULL
}

model Workspace {
  id            String         @id @default(uuid())
  name          String         @default("My Career Tree")
  shareToken    String?        @unique
  shareMode     ShareMode      @default(PRIVATE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  nodes         Node[]
  categories    Category[]
  crossLinks    CrossLink[]
  notifications Notification[]
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId       String?

  @@index([ownerId])
}

// Skill Tree: tang phan cap moi giua Workspace va Tier - 1 Workspace (=
// 1 "Skill Set") co nhieu Category (vd "Frontend", "Backend"), MOI Category
// co bo Tier rieng cua no (khong dung chung Tier giua cac Category).
model Category {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String? // mo ta ngan, hien trong Knowledge Block Summary
  icon        String? // slug icon (vd simple-icons/lucide), tuy chon
  color       String? // hex, dung cho khoi the Category ben trai canvas
  orderIndex  Int       @default(0)
  tiers       Tier[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

enum NotificationType {
  SYSTEM
  CONNECTION
}

model Notification {
  id          String           @id @default(uuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([workspaceId])
}

model Node {
  id               String      @id @default(uuid())
  workspaceId      String
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId         String?
  parent           Node?       @relation("NodeToNode", fields: [parentId], references: [id], onDelete: Cascade)
  children         Node[]      @relation("NodeToNode")
  kind             NodeKind    @default(BRANCH)
  category         String?
  difficulty       Difficulty?
  estimatedTime    String?
  prerequisites    String[]    @default([])
  learningOutcomes String[]    @default([])
  title            String
  goal             String?
  isPinned         Boolean     @default(false) //nut bookmark
  tags             String[]    @default([]) // Javascript, TypeScript, Nestjs.,...
  content          Json? // Tiptap/ProseMirror JSON — long-form notes for this node (distinct from Card, which is the quick activity log)
  depth            Int         @default(0)
  orderIndex       Int         @default(0)
  x                Float?
  y                Float?
  hiddenFromShare  Boolean     @default(false)
  isCollapsed      Boolean     @default(false)
  // Skill Tree: null = node chua gan tier (vd node cua Career Tree canvas cu),
  // gan Tier moi khi node duoc dat vao 1 vi tri tren skill tree.
  tierId           String?
  tier             Tier?       @relation(fields: [tierId], references: [id], onDelete: SetNull)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  cards            Card[]
  crossLinksFrom   CrossLink[] @relation("CrossLinkFrom")
  crossLinksTo     CrossLink[] @relation("CrossLinkTo")
  resources        Resource[]
  issues           Issue[]

  @@index([workspaceId, parentId])
  @@index([tierId])
}

// Tier thuoc ve 1 Category (khong con thuoc truc tiep Workspace) - moi
// Category co bo Tier rieng cua no.
model Tier {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label      String // "TIER 1"
  sublabel   String // "FOUNDATION"
  orderIndex Int      @default(0)
  nodes      Node[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
}

enum CardKind {
  NOTE
  PRACTICE
}

model Card {
  id         String   @id @default(uuid())
  nodeId     String
  node       Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  content    Json //Tiptap/ProseMirror JSON
  kind       CardKind @default(NOTE)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([nodeId])
}

enum ResourceType {
  ARTICLE
  VIDEO
  DOC
  COURSE
  BOOK
}

enum NodeKind {
  BRANCH
  TOPIC
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Resource {
  id         String       @id @default(uuid())
  nodeId     String
  node       Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  type       ResourceType
  title      String
  url        String
  orderIndex Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([nodeId])
}

model Issue {
  id        String   @id @default(uuid())
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  question  String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nodeId])
}

model CrossLink {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromNodeId  String
  fromNode    Node      @relation("CrossLinkFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId    String?
  toNode      Node?     @relation("CrossLinkTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  label       String?
  createdAt   DateTime  @default(now())

  @@unique([fromNodeId, toNodeId])
}

model User {
  id                String      @id @default(uuid())
  googleId          String      @unique
  email             String      @unique
  name              String
  // Dashboard Skill Tree: dung de so sanh benchmark theo nam kinh nghiem
  // (Phase 4) - de null neu nguoi dung chua khai bao.
  yearsOfExperience Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  workspaces        Workspace[]
}

model SystemFlag {
  id                 Int     @id @default(1)
  legacyBackfillDone Boolean @default(false)
}
