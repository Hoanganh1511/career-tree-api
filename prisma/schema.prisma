// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ShareMode {
  PRIVATE
  STRUCTURE_ONLY
  FULL
}

model Workspace {
  id            String         @id @default(uuid())
  name          String         @default("My Career Tree")
  shareToken    String?        @unique
  shareMode     ShareMode      @default(PRIVATE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  nodes         Node[]
  crossLinks    CrossLink[]
  notifications Notification[]
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId       String?

  @@index([ownerId])
}

enum NotificationType {
  SYSTEM
  CONNECTION
}

model Notification {
  id          String           @id @default(uuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([workspaceId])
}

model Node {
  id              String      @id @default(uuid())
  workspaceId     String
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Node?       @relation("NodeToNode", fields: [parentId], references: [id], onDelete: Cascade)
  children        Node[]      @relation("NodeToNode")
  title           String
  goal            String?
  content         Json? // Tiptap/ProseMirror JSON — long-form notes for this node (distinct from Card, which is the quick activity log)
  depth           Int         @default(0)
  orderIndex      Int         @default(0)
  x               Float?
  y               Float?
  hiddenFromShare Boolean     @default(false)
  isCollapsed     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  cards           Card[]
  crossLinksFrom  CrossLink[] @relation("CrossLinkFrom")
  crossLinksTo    CrossLink[] @relation("CrossLinkTo")
  resources       Resource[]
  issues          Issue[]

  @@index([workspaceId, parentId])
}

enum CardKind {
  NOTE
  PRACTICE
}

model Card {
  id         String   @id @default(uuid())
  nodeId     String
  node       Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  content    Json //Tiptap/ProseMirror JSON
  kind       CardKind @default(NOTE)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([nodeId])
}

enum ResourceType {
  ARTICLE
  VIDEO
  DOC
  COURSE
  BOOK
}

model Resource {
  id         String       @id @default(uuid())
  nodeId     String
  node       Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  type       ResourceType
  title      String
  url        String
  orderIndex Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([nodeId])
}

model Issue {
  id        String   @id @default(uuid())
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  question  String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nodeId])
}

model CrossLink {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromNodeId  String
  fromNode    Node      @relation("CrossLinkFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId    String?
  toNode      Node?     @relation("CrossLinkTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  label       String?
  createdAt   DateTime  @default(now())

  @@unique([fromNodeId, toNodeId])
}

model User {
  id         String      @id @default(uuid())
  googleId   String      @unique
  email      String      @unique
  name       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workspaces Workspace[]
}

model SystemFlag {
  id                 Int     @id @default(1)
  legacyBackfillDone Boolean @default(false)
}
