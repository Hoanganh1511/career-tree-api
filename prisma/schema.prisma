// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ShareMode {
  PRIVATE
  STRUCTURE_ONLY
  FULL
}

model Workspace {
  id         String      @id @default(uuid())
  name       String      @default("My Career Tree")
  shareToken String?     @unique
  shareMode  ShareMode   @default(PRIVATE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  nodes      Node[]
  crossLinks CrossLink[]
}

model Node {
  id              String      @id @default(uuid())
  workspaceId     String
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Node?       @relation("NodeToNode", fields: [parentId], references: [id], onDelete: Cascade)
  children        Node[]      @relation("NodeToNode")
  title           String
  depth           Int         @default(0)
  orderIndex      Int         @default(0)
  hiddenFromShare Boolean     @default(false)
  isCollapsed     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  cards           Card[]
  crossLinksFrom  CrossLink[] @relation("CrossLinkFrom")
  crossLinksTo    CrossLink[] @relation("CrossLinkTo")

  @@index([workspaceId, parentId])
}

model Card {
  id         String   @id @default(uuid())
  nodeId     String
  node       Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  content    Json //Tiptap/ProseMirror JSON
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([nodeId])
}

model CrossLink {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromNodeId  String
  fromNode    Node      @relation("CrossLinkFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId    String?
  toNode      Node?     @relation("CrossLinkTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  label       String?
  createdAt   DateTime  @default(now())

  @@unique([fromNodeId, toNodeId])
}
